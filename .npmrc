# --- pnpm store (fixes ERR_PNPM_EBUSY on some G: / synced / network drives) ---
# Uses a folder on C: so tarballs are not renamed under a locked G:\.pnpm-store.
# Linux/macOS: delete this line or set store-dir to a path on a local disk, e.g.
#   pnpm config set store-dir ~/.local/share/pnpm/store
store-dir=C:/pnpm-store

# Hoisted node_modules (fewer Windows PATH quirks with workspace scripts).
node-linker=hoisted
