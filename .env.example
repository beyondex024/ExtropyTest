# =============================================================================
# Root / general — copy to repo root as `.env` for local scripts if needed.
# =============================================================================

# -----------------------------------------------------------------------------
# apps/api — place a copy at: apps/api/.env
# (Serverless loads apps/api/.env when run from apps/api, or use shell export.)
# -----------------------------------------------------------------------------
# Required for API + database
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/extropy?retryWrites=true&w=majority
JWT_SECRET=use-a-long-random-string-at-least-32-chars

# Optional — AI category suggestions (AI Option B). If unset, suggestions are disabled with a clear UI message.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# apps/web — place a copy at: apps/web/.env
# -----------------------------------------------------------------------------
# Vite exposes only variables prefixed with VITE_
# Local API (serverless-offline default port 3000)
VITE_API_URL=http://localhost:3000

# Production: set to your deployed HTTP API base URL (no trailing slash)
# VITE_API_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com
