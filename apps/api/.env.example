# Copy to apps/api/.env (required for `pnpm --filter @extropy/api dev` / deploy)
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/extropy?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret-at-least-16-chars

# Optional: enables AI category suggestions (Option B)
OPENAI_API_KEY=

# Optional: tighten CORS in production (comma-separated origins supported by your deployment workflow)
CORS_ORIGIN=*

# Optional: debug | info | warn | error
LOG_LEVEL=info
